# ─────────────────────────────────────────────
# PoisonChain / Canisterworm 분석 도구 환경 설정
# cp .env.example .env 후 값을 채우세요.
# 이 파일(.env)은 절대 커밋하지 마세요.
# ─────────────────────────────────────────────

# ── XEIZE Open API ───────────────────────────
# scripts/canisterworm_analysis.py, bitbucket_full_scan.py 등
XEIZE_API_KEY=
XEIZE_BASE_URL=https://172.21.86.113/open-api/v1

# ── 사내 포털 계정 (tracert / infrase 자동 로그인) ──
# scripts/check_external_connectivity.py
# tracert.skplanet.com, infrase.skplanet.com 로그인에 사용
PNET_ID=1004276
PNET_PW=your_password

# ── Jenkins 스캔 ──────────────────────────────
# scripts/jenkins_scan.py

# [방법 1] 단일 서버 — URL + 토큰만 입력 (계정명 불필요, 자동 조회)
JENKINS_URL=https://your-jenkins.skplanet.com
JENKINS_TOKEN=11abc123def456789abcdef

# [방법 2] 토큰 뭉터기 — 여러 담당자에게 받은 토큰을 쉼표로 나열
#           서버마다 맞는 토큰을 자동으로 찾아 매칭
# JENKINS_TOKENS=token1,token2,token3,token4,...
#
# 계정명(사원번호)도 함께 제공하면 자동 매칭 속도 향상
# (미입력 시 admin/jenkins/user 순으로 시도)
# JENKINS_USERNAMES=1001050,1004276,1002345,1009999,...

# [방법 3] 서버별 지정 — jenkins-instances.json id 번호로 직접 지정
# JENKINS_TOKEN_1=11abc123...
# JENKINS_TOKEN_9=22def456...
