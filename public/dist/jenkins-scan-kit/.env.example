# Jenkins 공급망 공격 영향 분석 스캔 — 환경 설정

# 담당 Jenkins URL (필수)
JENKINS_URL=https://your-jenkins.example.com

# Jenkins API 토큰 (필수)
# 발급: Jenkins 로그인 → 우측 상단 계정명 → Configure → API Token → Add new Token
# 권한: Overall/Read + Job/Read + Job/ExtendedRead
# 형식: 계정:토큰 또는 토큰만
JENKINS_TOKEN=your-username:11abc123def456789abcdef
